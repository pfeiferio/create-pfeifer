{
  "name": "create-pfeifer",
  "version": "0.2.7",
  "description": "Scaffold new npm packages with @pfeiferio standards.",
  "author": "Pascal Pfeifer <pascal@pfeifer.zone>",
  "type": "module",
  "bin": {
    "create-pfeifer": "dist/cli/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "templates/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "dependencies": {
    "@pfeiferio/string-interpolate": "^1.0.0",
    "enquirer": "^2.4.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pfeiferio/create-pfeifer.git"
  },
  "bugs": {
    "url": "https://github.com/pfeiferio/create-pfeifer/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/pfeiferio/create-pfeifer#readme",
  "scripts": {
    "prepublishOnly": "npm test",
    "build": "npm run clean && tsc && cp -r templates dist/templates",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test",
    "test:coverage": "npm run build && node --test --experimental-test-coverage --test-coverage-exclude='test/**'",
    "test:coverage:c8": "npm run build && npx c8 node --test",
    "test:coverage:lcov": "npm run build && npx c8 --src src node --enable-source-maps --test",
    "dev": "npm run build && node dist/cli/cli.js"
  },
  "devDependencies": {
    "@types/node": "^20.17.9",
    "typescript": "^5.9.3"
  }
}
